<h1>Pets</h1>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner</th>
      <th>Birth</th>
    </tr>
  </thead>

  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= link_to pet.owner.first_name, pet.owner %></td>
        <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>