<h1>Appointments</h1>

<table class="table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>

  <tbody>
    <% @appointments.each do |a| %>
      <tr>
        <td><%= a.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to a.pet.name, a.pet %></td>
        <td><%= link_to a.vet.first_name, a.vet %></td>
        <td><%= a.reason %></td>
        <td><%= a.status&.humanize || "Sin estado" %>
      </tr>
    <% end %>
  </tbody>
</table>